# App
NODE_ENV=development
PORT=3000
APP_NAME=PhotonX WorkOS API
APP_VERSION=0.1.0

# Database (MySQL)
DATABASE_URL=mysql://photonx:photonx@localhost:3306/photonx_workos

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d

# Optional defaults
DEFAULT_TENANT_ID=
