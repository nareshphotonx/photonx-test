# App
NODE_ENV=development
PORT=3000
APP_NAME=PhotonX WorkOS API
APP_VERSION=0.1.0

# Database (MySQL)
DATABASE_URL=mysql://photonx:photonx@localhost:3306/photonx_workos
# Optional (recommended if DB user cannot create/drop databases)
SHADOW_DATABASE_URL=mysql://photonx:photonx@localhost:3306/photonx_workos_shadow

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# Integration secrets / app crypto
APP_ENCRYPTION_KEY=change-this-32-byte-secret
WHATSAPP_TEST_SECRET=change-this-test-secret

# AWS S3 (attachments)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_S3_BUCKET=photonx-workos-dev
AWS_S3_PRESIGN_EXPIRES_IN_SEC=900

# Optional defaults
DEFAULT_TENANT_ID=

# AI provider + RAG
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
AI_CONFIDENCE_THRESHOLD=0.65
AI_CACHE_TTL_SEC=600
AI_CHUNK_SIZE=1200
AI_CHUNK_OVERLAP=200
AI_SEARCH_TOP_K=5
