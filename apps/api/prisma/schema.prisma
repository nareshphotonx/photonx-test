generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum WorkWeekStart {
  MONDAY
  SUNDAY
  SATURDAY
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum ProjectMemberRole {
  OWNER
  MANAGER
  CONTRIBUTOR
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DependencyType {
  FINISH_TO_START
}

enum AttachmentStatus {
  PENDING
  UPLOADED
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum NotificationEventStatus {
  PENDING
  SENT
  FAILED
}

enum TimeEntrySource {
  MANUAL
  WHATSAPP
  GITHUB_PROMPT
  MANAGER_BULK
}

enum TimeEntryType {
  WORK
  ADJUSTMENT
}

enum BudgetAlertThreshold {
  P80
  P100
  P120
}

enum BudgetAlertStatus {
  PENDING
  SENT
  ACKNOWLEDGED
}

enum AttachmentEntityType {
  TASK
  EXPENSE
}

enum ApprovalTargetType {
  ATTENDANCE_REGULARIZATION
  LEAVE_REQUEST
  WFH_REQUEST
  EXPENSE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceEventType {
  CHECK_IN
  CHECK_OUT
  CORRECTION
}

enum AttendanceDayStatus {
  OPEN
  COMPLETE
  MISSING_CHECKOUT
  REGULARIZED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WfhRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

model Tenant {
  id                      String                   @id @default(cuid())
  name                    String
  slug                    String                   @unique
  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  settings                TenantSetting?
  users                   User[]
  teams                   Team[]
  roles                   Role[]
  permissions             Permission[]
  userRoles               UserRole[]
  rolePerms               RolePermission[]
  teamMembers             TeamMember[]
  officeIps               OfficeIp[]
  officeLocs              OfficeLocation[]
  sessions                AuthSession[]
  notifications           NotificationPreference[]
  projects                Project[]
  projectMembers          ProjectMember[]
  projectCosts            ProjectCost[]
  milestones              Milestone[]
  taskStatuses            TaskStatus[]
  taskWorkflows           TaskWorkflow[]
  taskWorkflowTransitions TaskWorkflowTransition[]
  tasks                   Task[]
  taskDependencies        TaskDependency[]
  taskComments            TaskComment[]
  taskCommentMentions     TaskCommentMention[]
  taskAttachments         TaskAttachment[]
  recurringTaskTemplates  RecurringTaskTemplate[]
  notificationEvents      NotificationEvent[]
  timeEntries             TimeEntry[]
  timeEntryUnlocks        TimeEntryUnlock[]
  rateCards               RateCard[]
  budgetAlerts            BudgetAlert[]
  attendanceDays          AttendanceDay[]
  attendanceEvents        AttendanceEvent[]
  attendanceRegularizations AttendanceRegularizationRequest[]
  leaveTypes              LeaveType[]
  leavePolicies           LeavePolicy[]
  leaveQuotaOverrides     LeaveUserQuotaOverride[]
  leaveAccrualLedgers     LeaveAccrualLedger[]
  leaveRequests           LeaveRequest[]
  wfhPolicies             WfhPolicy[]
  wfhQuotaOverrides       WfhUserQuotaOverride[]
  wfhRequests             WfhRequest[]
  holidays                Holiday[]
  optionalHolidayClaims   OptionalHolidayClaim[]
  optionalHolidayQuotaOverrides OptionalHolidayUserQuotaOverride[]
  expenseCategories       ExpenseCategory[]
  expensePolicies         ExpensePolicy[]
  expenses                Expense[]
  approvalRequests        ApprovalRequest[]
  approvalSteps           ApprovalStep[]

  @@index([isActive])
}

model TenantSetting {
  id            String        @id @default(cuid())
  tenantId      String        @unique
  timezone      String        @default("Asia/Kolkata")
  currency      String        @default("INR")
  workWeekStart WorkWeekStart @default(MONDAY)
  extras        Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id                      String                   @id @default(cuid())
  tenantId                String
  name                    String
  email                   String?
  phone                   String?
  passwordHash            String
  isActive                Boolean                  @default(true)
  deletedAt               DateTime?
  deletedBy               String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  teamMembership          TeamMember[]
  userRoles               UserRole[]
  sessions                AuthSession[]
  notification            NotificationPreference?
  projectMemberships      ProjectMember[]
  assignedTasks           Task[]                   @relation("TaskAssignee")
  authoredTaskComments    TaskComment[]            @relation("TaskCommentAuthor")
  mentionedInComments     TaskCommentMention[]     @relation("TaskCommentMentionedUser")
  uploadedTaskAttachments TaskAttachment[]         @relation("TaskAttachmentUploader")
  notificationEvents      NotificationEvent[]
  recurringTemplates      RecurringTaskTemplate[]  @relation("RecurringTemplateAssignee")
  timeEntries             TimeEntry[]
  timeEntryUnlocks        TimeEntryUnlock[]        @relation("TimeEntryUnlockActor")
  rateCards               RateCard[]
  attendanceDays          AttendanceDay[]
  attendanceEvents        AttendanceEvent[]
  attendanceRegularizations AttendanceRegularizationRequest[] @relation("RegularizationRequester")
  actedAttendanceRegularizations AttendanceRegularizationRequest[] @relation("RegularizationActor")
  leaveQuotaOverrides     LeaveUserQuotaOverride[]
  leaveAccrualLedgers     LeaveAccrualLedger[]
  leaveRequests           LeaveRequest[]           @relation("LeaveRequester")
  actedLeaveRequests      LeaveRequest[]           @relation("LeaveActor")
  wfhQuotaOverrides       WfhUserQuotaOverride[]
  wfhRequests             WfhRequest[]             @relation("WfhRequester")
  actedWfhRequests        WfhRequest[]             @relation("WfhActor")
  optionalHolidayClaims   OptionalHolidayClaim[]
  optionalHolidayQuotaOverrides OptionalHolidayUserQuotaOverride[]
  expenses                Expense[]                @relation("ExpenseSubmitter")
  actedExpenses           Expense[]                @relation("ExpenseActor")
  requestedApprovals      ApprovalRequest[]        @relation("ApprovalRequester")
  assignedApprovalSteps   ApprovalStep[]           @relation("ApprovalStepApprover")
  actedApprovalSteps      ApprovalStep[]           @relation("ApprovalStepActor")

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([tenantId, isActive])
  @@index([tenantId, deletedAt])
}

model Team {
  id                 String                  @id @default(cuid())
  tenantId           String
  name               String
  description        String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members            TeamMember[]
  projects           Project[]
  recurringTemplates RecurringTaskTemplate[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TeamMember {
  id        String   @id @default(cuid())
  tenantId  String
  teamId    String
  userId    String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, teamId, userId])
  @@index([tenantId, teamId])
  @@index([tenantId, userId])
}

model Role {
  id          String           @id @default(cuid())
  tenantId    String
  code        String
  name        String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Permission {
  id          String           @id @default(cuid())
  tenantId    String
  code        String
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles       RolePermission[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model RolePermission {
  id           String     @id @default(cuid())
  tenantId     String
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roleId, permissionId])
  @@index([tenantId, roleId])
  @@index([tenantId, permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId, userId])
  @@index([tenantId, roleId])
}

model OfficeLocation {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String
  latitude  Float?
  longitude Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendanceDays AttendanceDay[]
  holidays    Holiday[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model OfficeIp {
  id        String   @id @default(cuid())
  tenantId  String
  cidr      String
  label     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, cidr])
  @@index([tenantId, isActive])
}

model NotificationPreference {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String   @unique
  whatsappEnabled Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AuthSession {
  id               String   @id @default(cuid())
  tenantId         String
  userId           String
  refreshTokenHash String   @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([tenantId, expiresAt])
}

model Project {
  id               String         @id @default(cuid())
  tenantId         String
  teamId           String?
  name             String
  code             String
  description      String?
  status           ProjectStatus  @default(ACTIVE)
  budgetAmount     Decimal?       @db.Decimal(12, 2)
  budgetCurrency   String?
  overheadPercent  Decimal?       @db.Decimal(6, 2)
  startDate        DateTime?
  endDate          DateTime?
  nextTaskSequence Int            @default(101)
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  team             Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  members          ProjectMember[]
  milestones       Milestone[]
  taskStatuses     TaskStatus[]
  taskWorkflows    TaskWorkflow[]
  taskWorkflowTransitions TaskWorkflowTransition[]
  tasks            Task[]
  taskDependencies TaskDependency[]
  taskComments     TaskComment[]
  taskAttachments  TaskAttachment[]
  costs            ProjectCost[]
  recurringTasks   RecurringTaskTemplate[]
  timeEntries      TimeEntry[]
  budgetAlerts     BudgetAlert[]
  expenses         Expense[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, teamId])
  @@index([tenantId, deletedAt])
}

model ProjectMember {
  id        String            @id @default(cuid())
  tenantId  String
  projectId String
  userId    String
  role      ProjectMemberRole @default(CONTRIBUTOR)
  createdAt DateTime          @default(now())
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectId, userId])
  @@index([tenantId, projectId])
  @@index([tenantId, userId])
}

model ProjectCost {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String
  amount    Decimal  @db.Decimal(12, 2)
  currency  String
  category  String
  note      String?
  costDate  DateTime
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId])
  @@index([tenantId, projectId, costDate])
}

model Milestone {
  id          String          @id @default(cuid())
  tenantId    String
  projectId   String
  name        String
  description String?
  status      MilestoneStatus @default(PLANNED)
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  recurringTemplates RecurringTaskTemplate[]

  @@index([tenantId, projectId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, deletedAt])
}

model TaskStatus {
  id                   String                    @id @default(cuid())
  tenantId             String
  projectId            String
  name                 String
  code                 String
  description          String?
  color                String?
  position             Int                       @default(0)
  isDone               Boolean                   @default(false)
  requiresLocation     Boolean                   @default(false)
  requiresSelfie       Boolean                   @default(false)
  isDefault            Boolean                   @default(false)
  createdBy            String?
  updatedBy            String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  deletedAt            DateTime?
  tenant               Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project              Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks                Task[]
  workflowTransitionsFrom TaskWorkflowTransition[] @relation("WorkflowFromStatus")
  workflowTransitionsTo   TaskWorkflowTransition[] @relation("WorkflowToStatus")
  recurringTemplates   RecurringTaskTemplate[]

  @@unique([tenantId, projectId, code])
  @@index([tenantId, projectId, position])
  @@index([tenantId, projectId, isDone])
  @@index([tenantId, deletedAt])
}

model TaskWorkflow {
  id          String                   @id @default(cuid())
  tenantId    String
  projectId   String
  name        String
  isDefault   Boolean                  @default(false)
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  transitions TaskWorkflowTransition[]

  @@unique([tenantId, projectId, name])
  @@index([tenantId, projectId])
}

model TaskWorkflowTransition {
  id           String       @id @default(cuid())
  tenantId     String
  projectId    String
  workflowId   String
  fromStatusId String
  toStatusId   String
  createdAt    DateTime     @default(now())
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflow     TaskWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromStatus   TaskStatus   @relation("WorkflowFromStatus", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus     TaskStatus   @relation("WorkflowToStatus", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([tenantId, workflowId, fromStatusId, toStatusId])
  @@index([tenantId, projectId])
}

model Task {
  id                   String                 @id @default(cuid())
  tenantId             String
  projectId            String
  milestoneId          String?
  parentTaskId         String?
  recurringTemplateId  String?
  taskStatusId         String
  key                  String
  title                String
  description          String?
  assigneeId           String?
  estimateHours        Decimal?               @db.Decimal(8, 2)
  priority             TaskPriority           @default(MEDIUM)
  dueDate              DateTime?
  tags                 Json?
  externalReferences   Json?
  reopenedCount        Int                    @default(0)
  createdBy            String?
  updatedBy            String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deletedAt            DateTime?
  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project              Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone            Milestone?             @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  parentTask           Task?                  @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks             Task[]                 @relation("TaskSubtasks")
  status               TaskStatus             @relation(fields: [taskStatusId], references: [id], onDelete: Restrict)
  assignee             User?                  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  dependsOn            TaskDependency[]       @relation("TaskDependsOn")
  requiredBy           TaskDependency[]       @relation("TaskRequiredBy")
  comments             TaskComment[]
  attachments          TaskAttachment[]
  timeEntries          TimeEntry[]
  recurringTemplate    RecurringTaskTemplate? @relation(fields: [recurringTemplateId], references: [id], onDelete: SetNull)

  @@unique([tenantId, key])
  @@index([tenantId, projectId])
  @@index([tenantId, assigneeId])
  @@index([tenantId, projectId, taskStatusId])
  @@index([tenantId, projectId, milestoneId])
  @@index([tenantId, dueDate])
  @@index([tenantId, parentTaskId])
  @@index([tenantId, deletedAt])
}

model TaskDependency {
  id              String         @id @default(cuid())
  tenantId        String
  projectId       String
  taskId          String
  dependsOnTaskId String
  type            DependencyType @default(FINISH_TO_START)
  createdBy       String?
  createdAt       DateTime       @default(now())
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            Task           @relation("TaskDependsOn", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask   Task           @relation("TaskRequiredBy", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([tenantId, taskId, dependsOnTaskId])
  @@index([tenantId, projectId])
  @@index([tenantId, dependsOnTaskId])
}

model TaskComment {
  id        String               @id @default(cuid())
  tenantId  String
  projectId String
  taskId    String
  authorId  String
  content   String               @db.Text
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project   Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User                 @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  mentions  TaskCommentMention[]

  @@index([tenantId, taskId])
  @@index([tenantId, authorId])
}

model TaskCommentMention {
  id              String      @id @default(cuid())
  tenantId        String
  taskCommentId   String
  mentionedUserId String
  createdAt       DateTime    @default(now())
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  taskComment     TaskComment @relation(fields: [taskCommentId], references: [id], onDelete: Cascade)
  mentionedUser   User        @relation("TaskCommentMentionedUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, taskCommentId, mentionedUserId])
  @@index([tenantId, mentionedUserId])
}

model TaskAttachment {
  id          String           @id @default(cuid())
  tenantId    String
  entityType  AttachmentEntityType @default(TASK)
  entityId    String?
  projectId   String
  taskId      String?
  uploaderId  String
  s3Key       String
  fileName    String
  contentType String
  sizeBytes   Int?
  status      AttachmentStatus @default(PENDING)
  url         String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task        Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader    User             @relation("TaskAttachmentUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  expenseReceipts Expense[]    @relation("ExpenseReceiptAttachment")

  @@unique([tenantId, s3Key])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, taskId])
  @@index([tenantId, projectId])
}

model RecurringTaskTemplate {
  id                  String             @id @default(cuid())
  tenantId            String
  projectId           String
  milestoneId         String?
  teamId              String?
  defaultAssigneeId   String?
  statusId            String?
  name                String
  description         String?
  titleTemplate       String
  estimateHours       Decimal?           @db.Decimal(8, 2)
  priority            TaskPriority       @default(MEDIUM)
  tags                Json?
  externalReferences  Json?
  frequency           RecurringFrequency
  interval            Int                @default(1)
  startsAt            DateTime
  endsAt              DateTime?
  lastRunAt           DateTime?
  nextRunAt           DateTime
  isActive            Boolean            @default(true)
  createdBy           String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project             Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone           Milestone?         @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  team                Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  defaultAssignee     User?              @relation("RecurringTemplateAssignee", fields: [defaultAssigneeId], references: [id], onDelete: SetNull)
  status              TaskStatus?        @relation(fields: [statusId], references: [id], onDelete: SetNull)
  generatedTasks      Task[]

  @@index([tenantId, projectId])
  @@index([tenantId, isActive, nextRunAt])
}

model TimeEntry {
  id            String          @id @default(cuid())
  tenantId      String
  userId        String
  projectId     String
  taskId        String?
  parentEntryId String?
  entryDate     DateTime
  hours         Decimal         @db.Decimal(8, 2)
  type          TimeEntryType   @default(WORK)
  source        TimeEntrySource
  note          String?         @db.Text
  externalRef   String?
  rateSnapshot  Json
  costSnapshot  Json
  createdBy     String?
  createdAt     DateTime        @default(now())
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  parentEntry   TimeEntry?      @relation("TimeEntryAdjustments", fields: [parentEntryId], references: [id], onDelete: SetNull)
  adjustments   TimeEntry[]     @relation("TimeEntryAdjustments")
  unlocks       TimeEntryUnlock[]

  @@index([tenantId, userId, entryDate])
  @@index([tenantId, projectId, entryDate])
  @@index([tenantId, taskId, entryDate])
  @@index([tenantId, source, entryDate])
  @@index([tenantId, parentEntryId])
}

model TimeEntryUnlock {
  id          String    @id @default(cuid())
  tenantId    String
  timeEntryId String
  unlockedBy  String
  reason      String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timeEntry   TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  actor       User      @relation("TimeEntryUnlockActor", fields: [unlockedBy], references: [id], onDelete: Cascade)

  @@index([tenantId, timeEntryId])
  @@index([tenantId, unlockedBy, createdAt])
}

model RateCard {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  hourlyRate    Decimal  @db.Decimal(12, 2)
  currency      String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean  @default(true)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, effectiveFrom])
  @@index([tenantId, userId, effectiveFrom])
  @@index([tenantId, userId, isActive])
}

model BudgetAlert {
  id                   String               @id @default(cuid())
  tenantId             String
  projectId            String
  threshold            BudgetAlertThreshold
  status               BudgetAlertStatus    @default(PENDING)
  triggeredAt          DateTime             @default(now())
  burnAmountSnapshot   Decimal              @db.Decimal(12, 2)
  budgetAmountSnapshot Decimal              @db.Decimal(12, 2)
  notificationEventId  String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project              Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectId, threshold])
  @@index([tenantId, projectId, status])
}

model AttendanceDay {
  id                 String              @id @default(cuid())
  tenantId           String
  userId             String
  officeLocationId   String?
  date               DateTime
  checkInAt          DateTime?
  checkOutAt         DateTime?
  checkInIp          String?
  checkOutIp         String?
  checkInLatitude    Float?
  checkInLongitude   Float?
  checkOutLatitude   Float?
  checkOutLongitude  Float?
  isOffice           Boolean             @default(false)
  nonOfficeReason    String?
  lateMinutes        Int                 @default(0)
  earlyLogoutMinutes Int                 @default(0)
  isMissingCheckout  Boolean             @default(false)
  status             AttendanceDayStatus @default(OPEN)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  officeLocation     OfficeLocation?     @relation(fields: [officeLocationId], references: [id], onDelete: SetNull)
  events             AttendanceEvent[]
  regularizations    AttendanceRegularizationRequest[]

  @@unique([tenantId, userId, date])
  @@index([tenantId, date])
  @@index([tenantId, userId, date])
}

model AttendanceEvent {
  id              String              @id @default(cuid())
  tenantId        String
  userId          String
  attendanceDayId String
  type            AttendanceEventType
  occurredAt      DateTime
  ipAddress       String?
  latitude        Float?
  longitude       Float?
  isOffice        Boolean?
  reason          String?
  createdAt       DateTime            @default(now())
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendanceDay   AttendanceDay       @relation(fields: [attendanceDayId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, occurredAt])
  @@index([tenantId, attendanceDayId])
}

model AttendanceRegularizationRequest {
  id                 String         @id @default(cuid())
  tenantId           String
  userId             String
  attendanceDayId    String
  correctedCheckInAt DateTime
  correctedCheckOutAt DateTime
  reason             String
  status             ApprovalStatus @default(PENDING)
  actionReason       String?
  actedAt            DateTime?
  actedById          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User           @relation("RegularizationRequester", fields: [userId], references: [id], onDelete: Cascade)
  attendanceDay      AttendanceDay  @relation(fields: [attendanceDayId], references: [id], onDelete: Cascade)
  actedBy            User?          @relation("RegularizationActor", fields: [actedById], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, status])
  @@index([tenantId, attendanceDayId])
}

model LeaveType {
  id          String    @id @default(cuid())
  tenantId    String
  code        String
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policies    LeavePolicy[]
  requests    LeaveRequest[]
  overrides   LeaveUserQuotaOverride[]
  accruals    LeaveAccrualLedger[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model LeavePolicy {
  id                String   @id @default(cuid())
  tenantId          String
  leaveTypeId       String
  defaultAnnualQuota Decimal @db.Decimal(8, 2)
  monthlyAccrual    Decimal  @db.Decimal(8, 2)
  joiningProration  Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveType         LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, leaveTypeId])
  @@index([tenantId])
}

model LeaveUserQuotaOverride {
  id                String   @id @default(cuid())
  tenantId          String
  userId            String
  leaveTypeId       String
  annualQuota       Decimal  @db.Decimal(8, 2)
  monthlyAccrual    Decimal? @db.Decimal(8, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType         LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, leaveTypeId])
  @@index([tenantId, userId])
}

model LeaveAccrualLedger {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  leaveTypeId String
  year        Int
  month       Int
  amount      Decimal  @db.Decimal(8, 2)
  note        String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, leaveTypeId, year, month])
  @@index([tenantId, userId, year, month])
}

model LeaveRequest {
  id               String            @id @default(cuid())
  tenantId         String
  userId           String
  leaveTypeId      String
  startDate        DateTime
  endDate          DateTime
  totalDays        Decimal           @db.Decimal(8, 2)
  reason           String
  status           LeaveRequestStatus @default(PENDING)
  conflictMeta     Json?
  actionReason     String?
  actedAt          DateTime?
  actedById        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User              @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  leaveType        LeaveType         @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  actedBy          User?             @relation("LeaveActor", fields: [actedById], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, status])
  @@index([tenantId, startDate, endDate])
}

model WfhPolicy {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  defaultAnnualQuota Decimal  @db.Decimal(8, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model WfhUserQuotaOverride {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  annualQuota Decimal  @db.Decimal(8, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, userId])
}

model WfhRequest {
  id            String           @id @default(cuid())
  tenantId      String
  userId        String
  requestDate   DateTime
  reason        String
  status        WfhRequestStatus @default(PENDING)
  conflictMeta  Json?
  actionReason  String?
  actedAt       DateTime?
  actedById     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User             @relation("WfhRequester", fields: [userId], references: [id], onDelete: Cascade)
  actedBy       User?            @relation("WfhActor", fields: [actedById], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, status])
  @@index([tenantId, requestDate])
}

model Holiday {
  id               String         @id @default(cuid())
  tenantId         String
  locationId       String?
  name             String
  date             DateTime
  isOptional       Boolean        @default(false)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  location         OfficeLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  optionalClaims   OptionalHolidayClaim[]

  @@unique([tenantId, locationId, date, name])
  @@index([tenantId, date])
  @@index([tenantId, isOptional])
}

model OptionalHolidayClaim {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  holidayId  String
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  holiday    Holiday  @relation(fields: [holidayId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, holidayId])
  @@index([tenantId, userId, createdAt])
}

model OptionalHolidayUserQuotaOverride {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  annualQuota Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, userId])
}

model ExpenseCategory {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  description String?
  capAmount   Decimal? @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policies    ExpensePolicy[]
  expenses    Expense[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model ExpensePolicy {
  id           String   @id @default(cuid())
  tenantId     String
  categoryId   String
  categoryCap  Decimal? @db.Decimal(12, 2)
  requireApproval Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([tenantId, categoryId])
  @@index([tenantId])
}

model Expense {
  id                   String        @id @default(cuid())
  tenantId             String
  userId               String
  projectId            String
  categoryId           String
  amount               Decimal       @db.Decimal(12, 2)
  currency             String
  expenseDate          DateTime
  description          String
  status               ExpenseStatus @default(PENDING)
  receiptAttachmentId  String?
  actionReason         String?
  actedAt              DateTime?
  actedById            String?
  approvedProjectCostId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                 User          @relation("ExpenseSubmitter", fields: [userId], references: [id], onDelete: Cascade)
  project              Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category             ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  receiptAttachment    TaskAttachment? @relation("ExpenseReceiptAttachment", fields: [receiptAttachmentId], references: [id], onDelete: SetNull)
  actedBy              User?         @relation("ExpenseActor", fields: [actedById], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, status])
  @@index([tenantId, projectId, expenseDate])
  @@index([tenantId, categoryId])
}

model ApprovalRequest {
  id            String           @id @default(cuid())
  tenantId      String
  targetType    ApprovalTargetType
  targetId      String
  requesterId   String
  status        ApprovalStatus   @default(PENDING)
  currentStep   Int              @default(1)
  resolvedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requester     User             @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  steps         ApprovalStep[]

  @@unique([tenantId, targetType, targetId])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, requesterId, createdAt])
}

model ApprovalStep {
  id                String         @id @default(cuid())
  tenantId          String
  approvalRequestId String
  stepOrder         Int
  approverId        String
  status            ApprovalStatus @default(PENDING)
  actedAt           DateTime?
  actedById         String?
  reason            String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  approver          User           @relation("ApprovalStepApprover", fields: [approverId], references: [id], onDelete: Cascade)
  actedBy           User?          @relation("ApprovalStepActor", fields: [actedById], references: [id], onDelete: SetNull)

  @@unique([approvalRequestId, stepOrder])
  @@index([tenantId, approverId, status])
  @@index([tenantId, approvalRequestId])
}

model NotificationEvent {
  id          String                  @id @default(cuid())
  tenantId    String
  userId      String
  eventType   String
  channel     String
  payload     Json
  status      NotificationEventStatus @default(PENDING)
  attempts    Int                     @default(0)
  processedAt DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, status])
  @@index([tenantId, eventType])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}
