# PhotonX API environment template
# Copy to apps/api/.env for package-scoped runs, or keep values in repo-root .env.

NODE_ENV=development
PORT=3000
APP_NAME=PhotonX WorkOS API
APP_VERSION=0.1.0
APP_ENCRYPTION_KEY=replace-with-strong-32-byte-secret

DATABASE_URL=mysql://photonx:photonx@localhost:3306/photonx_workos
SHADOW_DATABASE_URL=mysql://photonx:photonx@localhost:3306/photonx_workos_shadow

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

THROTTLE_LIMIT=120
THROTTLE_TTL_MS=60000
THROTTLE_AUTH_LIMIT=20
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_WEBHOOK_LIMIT=300
THROTTLE_WEBHOOK_TTL_MS=60000
REQUEST_BODY_LIMIT_BYTES=1048576
CORS_ORIGINS=http://localhost:3001
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,x-tenant-id,x-request-id
CORS_CREDENTIALS=true
HELMET_ENABLE_CSP=false

JWT_SECRET=replace-with-jwt-secret
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

WHATSAPP_TEST_SECRET=replace-with-whatsapp-test-secret

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_S3_BUCKET=photonx-workos-dev
AWS_S3_PRESIGN_EXPIRES_IN_SEC=900

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
AI_CONFIDENCE_THRESHOLD=0.65
AI_CACHE_TTL_SEC=600
AI_CHUNK_SIZE=1200
AI_CHUNK_OVERLAP=200
AI_SEARCH_TOP_K=5

COMPLIANCE_EXPORT_RETENTION_DAYS=7

SEED_SUPER_ADMIN_PASSWORD=Admin@12345
SEED_TEAM_LEAD_PASSWORD=TeamLead@12345
SEED_USER_PASSWORD=User@12345
SEED_WHATSAPP_VERIFY_TOKEN=photonx-whatsapp-verify-token
SEED_WHATSAPP_APP_SECRET=photonx-whatsapp-app-secret
SEED_WHATSAPP_ACCESS_TOKEN=photonx-whatsapp-access-token
SEED_GITHUB_WEBHOOK_SECRET=photonx-github-webhook-secret
SEED_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
SEED_SMTP_USER=photonx-smtp-user
SEED_SMTP_PASSWORD=photonx-smtp-password
